---
import BaseLayout from "../layouts/BaseLayout.astro";
import Brand from "../components/Brand.astro";
---
<BaseLayout title="Work with Me">
    <Brand />

    <div class="work-card">
        <div class="work-content-container">
            <div class="main-work-content">
                <h2>Work with Me</h2>

                <div class="work-image">
                    <div class="work-image-placeholder" aria-hidden="true">
                        <span>Placeholder — photo or portrait of simplytriangle</span>
                    </div>
                </div>

                <h3>Brief Introduction</h3>
                <p>
                    I'm simplytriangle, the writer behind Coffee Break —
                    short stories, poetry, and folklore-driven analysis,
                    most of it circling back to myth and oral tradition.
                    Placeholder — a line or two on your writing
                    background, and what kind of projects you enjoy
                    working on most. Want the fuller story?
                    <a href="/about">Read more about me</a>.
                </p>

                <h3>What Can I Solve?</h3>
                <ul class="work-scenario-list">
                    <li>Placeholder — original short fiction or poetry for your publication, zine, or anthology</li>
                    <li>Placeholder — folklore/mythology research and retellings, adapted for a modern audience</li>
                    <li>Placeholder — narrative or descriptive copy for brands wanting a literary voice</li>
                    <li>Placeholder — developmental feedback or a line edit pass on an existing draft</li>
                </ul>

                <h3>When Will You Need My Help?</h3>
                <ul class="work-scenario-list">
                    <li>Placeholder — you're building an anthology or zine and need a folklore-rooted piece</li>
                    <li>Placeholder — you have a draft that needs an outside editorial eye before submission</li>
                    <li>Placeholder — you want copy that reads like a story, not a sales page</li>
                </ul>

                <div class="work-inquiry-cta">
                    <h3>Let's Work Together</h3>
                    <p>Tell me a bit about your project and timeline — I'll get back to you within a few days.</p>
                    <a href="mailto:hello@example.com" class="work-inquiry-link">Send an inquiry →</a>
                </div>
            </div>

            <div class="secondary-work-content">
                <div class="author-skills">
                    <h3>Author's Skills</h3>
                    <ul class="author-skill-list">
                        <li class="skill-item">Short fiction &amp; poetry</li>
                        <li class="skill-item">Folklore &amp; mythology research</li>
                        <li class="skill-item">Developmental editing</li>
                        <li class="skill-item">Line editing &amp; proofreading</li>
                        <li class="skill-item">Narrative &amp; brand copywriting</li>
                        <li class="skill-item">Ghostwriting</li>
                    </ul>
                </div>

                <div class="work-availability">
                    <span class="availability-dot" aria-hidden="true"></span>
                    <span>Placeholder — currently open for new projects</span>
                </div>
            </div>
        </div>
    </div>

</BaseLayout>